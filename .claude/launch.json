{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "insights",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-c",
        "import os,http.server,socketserver;port=int(os.environ.get('PORT','8792'));H=http.server.SimpleHTTPRequestHandler;H.extensions_map={**H.extensions_map,'.html':'text/html; charset=utf-8'};socketserver.TCPServer.allow_reuse_address=True;s=socketserver.TCPServer(('127.0.0.1',port),H);s.serve_forever()"
      ],
      "port": 8792,
      "autoPort": true,
      "cwd": "docs/insights"
    },
    {
