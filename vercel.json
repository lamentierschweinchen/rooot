{
  "installCommand": "npm install --prefix apps/web",
  "buildCommand": "npm --prefix apps/web run build",
  "outputDirectory": "apps/web/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/live",
      "destination": "/woven-loom?match=18213979"
    },
    {
      "source": "/demo",
      "destination": "/showcase"
    },
    {
      "source": "/loom",
      "destination": "/woven-loom"
    }
  ]
}
